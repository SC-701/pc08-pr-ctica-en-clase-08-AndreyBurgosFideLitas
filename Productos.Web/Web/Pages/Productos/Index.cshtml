@page
@model Web.Pages.Productos.IndexModel
@{
}
<h1>Listado de productos</h1>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary mb-0">Productos</h2>
    <a asp-page="./Agregar" class="btn btn-success rounded-pill px-4">
        Agregar producto
    </a>
</div>

<div class="row">

@if (Model.Productos != null && Model.Productos.Any())
{
        <div class="container mt-4">
            <div class="row g-4">
                @foreach (var producto in Model.Productos)
                {
                    <div class="col-12 col-sm-6 col-lg-4">
                        <div class="card h-100 shadow border-0 rounded-4">
                            <div class="card-body d-flex flex-column">

                                <div class="mb-3">
                                    <h5 class="card-title fw-bold text-primary mb-2">
                                        @Html.DisplayFor(modelo => producto.Nombre)
                                    </h5>
                                    <span class="badge bg-light text-dark border">
                                        Producto
                                    </span>
                                </div>

                                <div class="mb-3">
                                    <p class="card-text mb-2">
                                        <strong>ID:</strong><br />
                                        <span class="text-muted small">@Html.DisplayFor(modelo => producto.Id)</span>
                                    </p>

                                    <p class="card-text mb-0">
                                        <strong>Precio:</strong><br />
                                        <span class="fs-5 fw-semibold text-success">
                                            ₡ @Html.DisplayFor(modelo => producto.Precio)
                                        </span>
                                    </p>
                                </div>

                                <div class="mt-auto d-flex gap-2">
                                    <a asp-page="./Detalle" asp-route-id="@producto.Id" class="btn btn-outline-primary btn-sm rounded-pill">
                                        Ver detalle
                                    </a>
                                    <a asp-page="./Editar" asp-route-id="@producto.Id" class="btn btn-primary btn-sm rounded-pill">
                                        Editar
                                    </a>
                                    <a asp-page="./Eliminar" asp-route-id="@producto.Id" class="btn btn-outline-danger btn-sm rounded-pill">
                                        Eliminar
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
}
else
{
        <div class="alert alert-info mt-4 rounded-4 shadow-sm">
            No hay productos disponibles.
        </div>
}
